# ==============================================================================
# ST7 全球交易平台 - 生产环境配置
# ==============================================================================
# 复制此文件为 .env.production 并填写实际的配置值
# 注意：此文件包含敏感信息，请勿提交到 Git
# ==============================================================================

# ------------------------------------------------------------------------------
# Supabase 配置
# ------------------------------------------------------------------------------
# 从 Supabase 控制台获取这些值
COZE_SUPABASE_URL=https://your-project.supabase.co
COZE_SUPABASE_ANON_KEY=your-anon-key
COZE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ------------------------------------------------------------------------------
# 应用配置
# ------------------------------------------------------------------------------
# 运行环境
NODE_ENV=production

# 应用端口
PORT=5000

# 应用域名（用于生成绝对 URL）
APP_URL=https://forexpl.shop

# API 基础 URL
NEXT_PUBLIC_API_BASE_URL=https://forexpl.shop/api

# ------------------------------------------------------------------------------
# 时区和日志
# ------------------------------------------------------------------------------
# 时区
TZ=UTC

# 日志级别: debug, info, warn, error
LOG_LEVEL=info

# ------------------------------------------------------------------------------
# 数据库配置（备用，不使用）
# ------------------------------------------------------------------------------
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trading_platform

# ------------------------------------------------------------------------------
# 管理员账号（首次运行时创建）
# ------------------------------------------------------------------------------
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# ------------------------------------------------------------------------------
# 安全配置
# ------------------------------------------------------------------------------
# JWT Secret（用于会话管理）
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Session 密钥
SESSION_SECRET=your-super-secret-session-key-change-this-in-production

# API 密钥（如果需要调用外部 API）
# EXTERNAL_API_KEY=your-external-api-key

# ------------------------------------------------------------------------------
# 功能开关
# ------------------------------------------------------------------------------
# 启用注册功能
ENABLE_REGISTRATION=true

# 启用模拟交易
ENABLE_DEMO_TRADING=true

# 启用正式交易
ENABLE_REAL_TRADING=true

# 启用风控系统
ENABLE_RISK_CONTROL=true

# ------------------------------------------------------------------------------
# 邮件配置（用于发送通知）
# ------------------------------------------------------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@forexpl.shop

# ------------------------------------------------------------------------------
# 监控和告警
# ------------------------------------------------------------------------------
# Sentry DSN（用于错误监控）
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Analytics ID（用于流量统计）
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
