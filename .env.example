# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trading_platform

# JWT Authentication Keys (Required)
# 生成方式: openssl rand -base64 32
JWT_USER_SECRET=your-user-jwt-secret-at-least-32-chars
JWT_ADMIN_SECRET=your-admin-jwt-secret-at-least-32-chars

# 注意：管理员账号现在必须通过数据库管理
# 请在 admin_users 表中创建管理员账号

# API (可选，如果需要对接外部 API)
# NEXT_PUBLIC_API_BASE_URL=http://localhost:5000/api
